# ==============================
# 環境變數設定範本
# 本地開發 / Railway 部署皆適用
# ==============================

# 環境 (development / production)
ENVIRONMENT=development

# Database
# 本地開發用 SQLite:
DATABASE_URL=sqlite:///./taiwan_stock.db
# Railway PostgreSQL (部署時自動提供):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret — 生產環境必須設定安全的隨機密鑰！
JWT_SECRET=your-random-secret-key-here

# API Keys
FINMIND_TOKEN=your_value_here
FUGLE_API_KEY=your_value_here
GOOGLE_API_KEY=your_value_here
GROQ_API_KEY=your_value_here

# Google OAuth
GOOGLE_CLIENT_ID=your_value_here
GOOGLE_CLIENT_SECRET=your_value_here

# AI Models
AI_MODEL=gemini-2.0-flash
AI_MODEL_FREE=gemini-2.0-flash
AI_MODEL_PRO=gemini-2.5-pro
GROQ_MODEL=llama-3.3-70b-versatile

# FRED API (宏觀經濟數據，選填)
FRED_API_KEY=your_value_here

# CORS — 生產前端域名（逗號分隔）
CORS_ORIGINS=http://localhost:5000,http://localhost:3000,http://localhost:8080,https://stockapp-backend-ein8.onrender.com
