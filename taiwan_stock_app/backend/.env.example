# Database (use SQLite for local development)
DATABASE_URL=your_value_here
# DATABASE_URL=your_value_here

# API Keys
FINMIND_TOKEN=your_value_here
FUGLE_API_KEY=your_value_here
GOOGLE_API_KEY=your_value_here
# Google OAuth
GOOGLE_CLIENT_ID=your_value_here
GOOGLE_CLIENT_SECRET=your_value_here

# JWT Secret
JWT_SECRET=your_value_here

# AI Model (Google Gemini) - Default model
AI_MODEL=your_value_here

# AI Models by subscription tier
AI_MODEL_FREE=your_value_here
AI_MODEL_PRO=your_value_here

# Groq API (fallback when Gemini quota exceeded)
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your_value_here
GROQ_MODEL=your_value_here
